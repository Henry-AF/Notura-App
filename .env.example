# Copy this file to .env.local and replace the placeholders with your local values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_WEBHOOK_SECRET=your-assemblyai-webhook-secret

R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-public-bucket-url.example.com

EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=notura

WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_API_VERSION=v25.0
WHATSAPP_API_BASE_URL=
OPERATOR_WHATSAPP_NUMBER=5511999999999

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_STARTER_MONTHLY_PRICE_ID=price_starter_monthly
STRIPE_STARTER_YEARLY_PRICE_ID=price_starter_yearly
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly

ABACATEPAY_API_KEY=your-abacatepay-api-key
ABACATEPAY_STARTER_MONTHLY_PRODUCT_ID=starter_monthly_product_id
ABACATEPAY_STARTER_YEARLY_PRODUCT_ID=starter_yearly_product_id
ABACATEPAY_PRO_MONTHLY_PRODUCT_ID=pro_monthly_product_id
ABACATEPAY_PRO_YEARLY_PRODUCT_ID=pro_yearly_product_id

# Legacy fallbacks kept for compatibility with older environments.
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
ABACATEPAY_PRO_PRODUCT_ID=
ABACATEPAY_PLATINUM_PRODUCT_ID=

# Inngest Cloud keys are required in production. Local development can use INNGEST_DEV=1.
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
INNGEST_DEV=1
INNGEST_BASE_URL=http://localhost:8288

NEXT_PUBLIC_APP_URL=https://app.notura.com.br
