# ─────────────────────────────────────────────────────────────────────────────
# Notura — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and keys from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://veugfrzbghmojzmrmrul.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_-lFwM7qXVV1BncsLyxcMEQ_qmgvJfq8
SUPABASE_SERVICE_ROLE_KEY=http://localhost:3000

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# API key from console.anthropic.com → API Keys
# Used for meeting summarization (WhatsApp + JSON)
ANTHROPIC_API_KEY=

# ── AssemblyAI ────────────────────────────────────────────────────────────────
# API key from assemblyai.com → Dashboard
# Used for audio transcription with Portuguese (pt) support
ASSEMBLYAI_API_KEY=

# ── Cloudflare R2 (Audio Storage) ────────────────────────────────────────────
# Credentials from Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=notura-audio
# Optional: public URL if R2 bucket has public access enabled
R2_PUBLIC_URL=

# ── Evolution API (WhatsApp) ─────────────────────────────────────────────────
# Self-hosted Evolution API instance (e.g., Railway deployment)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=notura
# Operator number receives error alerts (format: 5511999999999)
OPERATOR_WHATSAPP_NUMBER=

# ── Stripe (Payments) ────────────────────────────────────────────────────────
# Keys from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── AbacatePay (Pix Payments) ────────────────────────────────────────────────
# API key from AbacatePay dashboard
ABACATEPAY_API_KEY=

# ── Inngest (Background Jobs) ────────────────────────────────────────────────
# Keys from Inngest dashboard → Manage → Signing Key / Event Key
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Public-facing URL (used for callbacks, redirects, meta tags)
NEXT_PUBLIC_APP_URL=https://app.notura.com.br
